#, c-format
msgid "      Reject using a reviewer-supplied condition instead.\n"
msgstr "      reviewer が指定した condition を使って reject します。\n"

#: src/issue.c:1134
#, c-format
msgid "      Reject using the requested condition if one is active.\n"
msgstr ""
"      requested condition が active の場合はそれを使って reject します。\n"

