#, c-format
msgid "      Entity subcommands under 'env', 'user', 'issue', and 'domain'\n"
msgstr "      'env'、'user'、'issue'、'domain' 配下の subcommand も\n"

#: src/issue.c:1144
#, c-format
msgid ""
"      Invalidate only the requested condition and keep the issue itself "
"active.\n"
msgstr ""
"      requested condition のみを無効化し、issue 自体は active のままにしま"
"す。\n"

