#, c-format
msgid "      Remove the requested condition while the issue is still open.\n"
msgstr "      issue が open の間、requested condition を削除します。\n"

#: src/issue.c:1142
#, c-format
msgid "      Return a held issue to open state.\n"
msgstr "      hold 中の issue を open 状態へ戻します。\n"

